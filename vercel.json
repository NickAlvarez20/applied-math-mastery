{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm run build",
      "outputDirectory": "dist"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/api",
      "entrypoint": "main.go",
      "framework": "go",
      "memory": 512,
      "maxDuration": 10,
      "includeFiles": "data/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/_/backend/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
