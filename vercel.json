{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/api",
      "entrypoint": "main.go",
      "framework": "go"
    }
  },
  "rewrites": [{ "source": "/api/:path*", "destination": "/_/backend" }]
}
